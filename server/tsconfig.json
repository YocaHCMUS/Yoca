{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "outDir": "./build",
    "paths": {
      "@sv/*": [
        "./src/*"
      ]
    },
    "strict": true,
    "strictNullChecks": true
  },
  "include": [
    "src/**/*",
    "tests/api-manager/api-manager.service.integration.test.ts",
    "tests/api-manager/api-manager.service.queue.test.ts",
    "tests/api-manager/api-manager.service.test.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}