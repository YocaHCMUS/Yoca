COINGECKO_API_BASE_URL=
SIM_API_BASE_URL=
BITQUERY_STREAM_API_ENDPOINT=
BITQUERY_API_ENDPOINT=

COINGECKO_API_KEY=
SIM_API_KEY=
BITQUERY_API_KEY=
BIRDEYE_API_KEY=
MORALIS_API_KEY=
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENABLED=false
BRAVE_MONTHLY_SOFT_LIMIT=
BRAVE_MONTHLY_USED_OFFSET=0
POSTGRES_DB_URL=
REDIS_URL=redis://localhost:6379 # default Redis URL, update if different, use in-memory cache if not using Redis
WALLET_USE_ACMS=false # set to true to route wallet-related API calls through ACMS (for better caching and rate limit management)

# Server Port
SERVER_PORT=4000

# Auth configuration
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth

# Password reset email (backend-only Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
APP_NAME=Yoca

# Client
CLIENT_LOCAL_DOMAIN=http://localhost:3000
CLIENT_DEV_DOMAIN=http://localhost:3000
CLIENT_PROD_DOMAIN=http://localhost:3000

# AI Wallet Forensic Auditor (Gemini)
GOOGLE_AI_KEY=
# Optional override; defaults to "gemini-3-flash"
GEMINI_AUDIT_MODEL=

TRANSACTION_FETCH_MAX_PAGE_COUNT=10
TRANSACTION_FETCH_MAX_ITEM_COUNT=500

# ─────────────────────────────────────────────────────
# Stripe (backend-only, never expose to client)
# ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_LITE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# ─────────────────────────────────────────────────────
# Solana Payment (backend verification)
# ─────────────────────────────────────────────────────
# SOLANA_MERCHANT_ADDRESS must match VITE_SOLANA_MERCHANT_ADDRESS in client/.env.
# The server uses this to independently verify the recipient of every payment.
SOLANA_MERCHANT_ADDRESS=
# HELIUS_API_KEY: backend-only RPC key for Solana transaction verification.
# Supports comma-separated list for key rotation (uses first valid key).
# NEVER put this in client/.env.
HELIUS_API_KEY=
# HELIUS_WEBHOOK_AUTH_KEY: secret used to validate inbound Helius webhook calls.
HELIUS_WEBHOOK_AUTH_KEY=
HELIUS_WEBHOOK_ID=
