COINGECKO_API_BASE_URL=
SIM_API_BASE_URL=
BITQUERY_STREAM_API_ENDPOINT=
BITQUERY_API_ENDPOINT=

COINGECKO_API_KEY=
SIM_API_KEY=
BITQUERY_API_KEY=
BIRDEYE_API_KEY=
MORALIS_API_KEY=
ZERION_API_KEY=
ZERION_API_BASE_URL=https://api.zerion.io/v1
MOBULA_API_KEY=
MOBULA_API_BASE_URL=https://api.mobula.io/api
MORALIS_API_BASE_URL=https://solana-gateway.moralis.io
BIRDEYE_API_BASE_URL=https://public-api.birdeye.so
BITQUERY_TOKENGEN_ENDPOINT=
BITQUERY_CLIENT_IDS=
BITQUERY_CLIENT_SECRETS=
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENABLED=false
BRAVE_MONTHLY_SOFT_LIMIT=
BRAVE_MONTHLY_USED_OFFSET=0
POSTGRES_DB_URL=
REDIS_URL=redis://localhost:6379 # default Redis URL, update if different, use in-memory cache if not using Redis
WALLET_USE_ACMS=false # set to true to route wallet-related API calls through ACMS (for better caching and rate limit management)

# Server Port
SERVER_PORT=4000

# Auth configuration
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth

# Password reset email (backend-only Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
APP_NAME=Yoca

# Client
CLIENT_LOCAL_DOMAIN=http://localhost:3000
CLIENT_DEV_DOMAIN=http://localhost:3000
CLIENT_DEV_PREVIEW_DOMAIN=http://localhost:4173
CLIENT_PROD_DOMAIN=http://localhost:3000

# AI Wallet Forensic Auditor (Gemini)
GOOGLE_AI_KEY=
# Optional override; defaults to "gemini-3-flash"
GEMINI_AUDIT_MODEL=

GEMINI_SWAP_SUMMARY_MODEL=
CHAT_MODEL=
AI_USAGE_LIMIT_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODAL=gemini-3.1-flash-lite
TOKEN_AI_CHAT_MODEL=
TOKEN_AI_CHAT_BALANCED_MODEL=
TOKEN_AI_CHAT_FALLBACK_MODEL=
TOKEN_AI_CHAT_FAST_MODEL=
TOKEN_AI_CHAT_PROMPT_VERSION=v4
TOKEN_CHART_NEWS_SUMMARY_MODEL=
TOKEN_VOLATILITY_SUMMARY_MODEL=

TRANSACTION_FETCH_MAX_PAGE_COUNT=10
TRANSACTION_FETCH_MAX_ITEM_COUNT=500

# ─────────────────────────────────────────────────────
# AI Wallet Analysis (n8n webhook)
# ─────────────────────────────────────────────────────
N8N_ANALYSE_WALLET_URL=http://localhost:5678/webhook/analyse-wallet
N8N_ANALYSIS_TIMEOUT_MS=200000
N8N_LATEST_NEWS_URL=
WALLET_AI_ANALYSIS_WEBHOOK_URL=http://localhost:5678/webhook/analyse-wallet
WALLET_AI_ANALYSIS_TIMEOUT_MS=180000
WALLET_AI_ANALYSIS_CACHE_TTL_MS=10800000
WALLET_AI_MODEL_VERSION=
WALLET_AI_PROMPT_VERSION=

# ─────────────────────────────────────────────────────
# Email (Resend, alternative to SMTP above)
# ─────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=
FROM_EMAIL=

# ─────────────────────────────────────────────────────
# API call tracking (dev/debug)
# ─────────────────────────────────────────────────────
API_CALL_TRACKER_ENABLED=false
API_CALL_TRACKER_EXPORT_DIR=

# ─────────────────────────────────────────────────────
# Stripe (backend-only, never expose to client)
# ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_LITE=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────
# Solana Payment (backend verification)
# ─────────────────────────────────────────────────────
# SOLANA_MERCHANT_ADDRESS must match VITE_SOLANA_MERCHANT_ADDRESS in client/.env.
# The server uses this to independently verify the recipient of every payment.
SOLANA_MERCHANT_ADDRESS=
# SOLANA_NETWORK must match VITE_SOLANA_NETWORK in client/.env.
SOLANA_NETWORK=devnet
# HELIUS_API_KEY: backend-only RPC key for Solana transaction verification.
# Supports comma-separated list for key rotation (uses first valid key).
# NEVER put this in client/.env.
HELIUS_API_KEY=
HELIUS_API_BASE_URL=https://api.helius.xyz
HELIUS_AUTH_HEADER=
WEBHOOK_SOL_PRICE_USD=150
# HELIUS_WEBHOOK_AUTH_KEY: secret used to validate inbound Helius webhook calls.
HELIUS_WEBHOOK_AUTH_KEY=
# WEBHOOK_PUBLIC_URL: public server origin or /webhook URL for managed Helius shard callbacks.
# Prefer this value for local/ngrok cutovers; it wins if PUBLIC_WEBHOOK_URL is also set.
WEBHOOK_PUBLIC_URL=
# PUBLIC_WEBHOOK_URL is also supported as a fallback.
PUBLIC_WEBHOOK_URL=
# HELIUS_WEBHOOK_ID is deprecated. Do not use it for managed shard mode.
# Keep it only temporarily for cutover warning/delete command, then remove it.
HELIUS_WEBHOOK_ID=
