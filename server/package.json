{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "npm run clean && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node build/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "clear": "rimraf ./node_modules && npm run clean",
    "clean": "rimraf ./build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --verbose",
    "db:push-force": "drizzle-kit push --verbose --force",
    "alerts:replay": "tsx src/scripts/replay-wallet-alert-webhook.ts",
    "alerts:sync-helius": "tsx src/scripts/sync-helius-webhook-shards.ts",
    "alerts:verify-helius-cutover": "tsx src/scripts/verify-helius-cutover.ts",
    "alerts:disable-legacy-helius": "tsx src/scripts/disable-legacy-helius.ts",
    "db:studio": "drizzle-kit studio",
    "db:clear": "drizzle-kit push --force --config drizzle-empty.config.ts",
    "db:reset": "npm run db:clear && npm run db:push"
  },
  "dependencies": {
    "@coingecko/coingecko-typescript": "^3.1.0",
    "@google/genai": "^1.50.1",
    "@hono/node-server": "^1.19.6",
    "@solana/kit": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "bottleneck": "^2.19.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "google-auth-library": "^10.5.0",
    "helius-sdk": "^2.2.2",
    "hono": "^4.10.4",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.7",
    "redis": "^5.11.0",
    "resend": "^6.12.2",
    "rss-parser": "^3.13.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.7",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  }
}
