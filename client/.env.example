# ─────────────────────────────────────────────────────────────────────────────
# Yoca Client — Environment Variables
# Copy this file to .env.development (or .env) and fill in the values.
# Only variables prefixed with VITE_ are accessible inside the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# App Identity
VITE_APP_NAME=Yoca
VITE_APP_ENV=development

# Backend API base URL (the Hono server)
VITE_CLIENT_API_DOMAIN=http://localhost:4000

# Google OAuth
VITE_GOOGLE_CLIENT_ID=

# CoinGecko (client-side market data)
VITE_COINGECKO_API_KEY=
VITE_COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Stripe publishable key (safe to expose to the browser)
VITE_STRIPE_PUBLISHABLE_KEY=

# Solana network configuration
# Valid values: devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=testnet
# Public RPC endpoint for building and signing transactions (NOT for verification).
VITE_SOLANA_RPC_URL=https://api.testnet.solana.com
# Merchant's public Solana address — the destination of SOL payments.
# This is NOT a secret. Security comes from the server verifying independently.
# Must match SOLANA_MERCHANT_ADDRESS in server/.env.
VITE_SOLANA_MERCHANT_ADDRESS=

# Feature flags
VITE_USE_WALLET_MOCKS=false

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  NEVER add the following types of keys here:
#   • HELIUS_API_KEY        → belongs in server/.env
#   • STRIPE_SECRET_KEY     → belongs in server/.env
#   • Database URLs         → belongs in server/.env
#   • JWT secrets           → belongs in server/.env
#   • Any key without VITE_ prefix (Vite will not expose it to the browser)
# ─────────────────────────────────────────────────────────────────────────────