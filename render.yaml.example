# Rename to render.yaml only if you intentionally want Render Blueprint/IaC management.
# For your existing services, update the same values in Render Dashboard instead.
services:
  - type: web
    runtime: node
    name: yoca-api-REPLACE-ME
    plan: free
    buildCommand: npm install && npm run server:build
    startCommand: npm run server:preview
    healthCheckPath: /api
    autoDeployTrigger: commit
    envVars:
      - key: NODE_ENV
        value: production
      - key: SERVER_PORT
        value: "10000"
      - key: POSTGRES_DB_URL
        sync: false
      - key: JWT_SECRET
        generateValue: true
      - key: GOOGLE_CLIENT_ID
        sync: false
      - key: CLIENT_PROD_DOMAIN
        sync: false
      - key: COINGECKO_API_KEY
        sync: false
      - key: BIRDEYE_API_KEY
        sync: false
      - key: ZERION_API_KEY
        sync: false
      - key: HELIUS_API_KEY
        sync: false
      - key: HELIUS_WEBHOOK_AUTH_KEY
        sync: false
      - key: MORALIS_API_KEY
        sync: false
      - key: MOBULA_API_KEY
        sync: false
      - key: AI_USAGE_LIMIT_ENABLED
        value: "true"

  - type: web
    runtime: static
    name: yoca-web-REPLACE-ME
    buildCommand: npm install && npm run client:build
    staticPublishPath: ./client/build
    autoDeployTrigger: commit
    envVars:
      - key: VITE_APP_ENV
        value: production
      - key: VITE_CLIENT_API_DOMAIN
        sync: false
      - key: VITE_API_DOMAIN
        sync: false
      - key: VITE_GOOGLE_CLIENT_ID
        sync: false
      - key: VITE_STRIPE_PUBLISHABLE_KEY
        sync: false
      - key: VITE_SOLANA_NETWORK
        sync: false
      - key: VITE_SOLANA_RPC_URL
        sync: false
      - key: VITE_SOLANA_MERCHANT_ADDRESS
        sync: false
      - key: VITE_USE_WALLET_MOCKS
        value: "false"
      - key: VITE_PROFILE_DATA_SOURCE
        value: api
    routes:
      - type: rewrite
        source: /*
        destination: /index.html
